<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ai-book.matepad-control</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Applications/MatePadControl.app/Contents/MacOS/MatePadControl</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/matepad-control.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/matepad-control.err</string>
</dict>
</plist>
