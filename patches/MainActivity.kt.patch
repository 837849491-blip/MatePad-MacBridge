+    private fun setupDoubaoVoiceButton() {
+        binding.doubaoVoiceButton.setOnClickListener {
+            lifecycleScope.launch(Dispatchers.IO) {
+                try {
+                    URL("http://127.0.0.1:18765/voice").openStream().use { }
+                    runOnUiThread { updateStatus("Doubao voice triggered") }
+                } catch (e: Exception) {
+                    runOnUiThread { updateStatus("Doubao voice unavailable: ${e.message}") }
+                }
+            }
+        }
+    }
+
+    private fun sendMacDirectTouch(
+        x: Float,
+        y: Float,
+        type: Int,
+    ) {
+        val now = SystemClock.uptimeMillis()
+        if (type == 1 && now - lastDirectTouchMs < 16L) return
+        lastDirectTouchMs = now
+        lifecycleScope.launch(Dispatchers.IO) {
+            try {
+                URL("http://127.0.0.1:18765/touch?x=$x&y=$y&type=$type").openStream().use { }
+            } catch (_: Exception) {
+                // Native SideScreen touch remains active if the local control bridge is unavailable.
+            }
+        }
     }
 
